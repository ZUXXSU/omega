# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing
android/keystore.jks
android/key.properties
keystore.jks
key.properties

# Firebase / Google Services (real credentials — use *.example files as reference)
google-services.json
GoogleService-Info.plist

# Dart code generation artifacts
*.g.dart
*.freezed.dart

# Environment variables
.env
.env.*

# Lock files — keep pubspec.lock, ignore others
# pubspec.lock is intentionally NOT ignored (pinned deps for reproducible builds)
yarn.lock
package-lock.json
